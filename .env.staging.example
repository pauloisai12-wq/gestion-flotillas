# ────────────────────────────────────────────────────────────────
# .env para QA/Staging en el servidor de casa (VPN + Caddy, endurecido).
# Copia este archivo a `.env` EN EL SERVIDOR y completa los secretos.
# NUNCA commitees el .env real.
#
#   cp .env.staging.example .env && nano .env
#
# Se usa junto al override:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml ...
# ────────────────────────────────────────────────────────────────

# ─── Entorno ────────────────────────────────────────────────────
# Endurecido: dispara las validaciones estrictas de api/src/config/env.ts.
NODE_ENV=production
PORT=3001

# ─── Base de datos PostgreSQL 16 (contenedor dedicado) ──────────
POSTGRES_USER=flotillas_app
POSTGRES_PASSWORD=CAMBIA_ESTO_password_fuerte
POSTGRES_DB=flotillas
# host = "postgres" (servicio en la red de compose); puerto interno 5432.
# connection_limit 20 sobra para 5 usuarios + BullMQ + jobs + healthchecks.
DATABASE_URL=postgresql://flotillas_app:CAMBIA_ESTO_password_fuerte@postgres:5432/flotillas?connection_limit=20
# Solo si publicas el puerto de Postgres (NO en este override): scripts/CLI en el host.
# DATABASE_URL_LOCAL=postgresql://flotillas_app:CAMBIA_ESTO_password_fuerte@localhost:5433/flotillas

# ─── Redis (contenedor dedicado) ────────────────────────────────
# Contraseña de Redis (--requirepass). OBLIGATORIA: el docker-compose la exige.
REDIS_PASSWORD=CAMBIA_ESTO_password_redis_fuerte
# La URL DEBE incluir la contraseña: redis://:<password>@host:puerto
REDIS_URL=redis://:CAMBIA_ESTO_password_redis_fuerte@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Red / Proxy ────────────────────────────────────────────────
# Caddy -> web(Next) -> API = 2 saltos. Verifica que Next reenvíe el
# X-Forwarded-For del cliente; ajusta el número si la topología cambia.
# NUNCA 'true' (permitiría spoofing de X-Forwarded-For).
TRUST_PROXY=2

# ─── Autenticación / JWT ────────────────────────────────────────
# OBLIGATORIO en producción: >= 64 caracteres. Genera uno con:
#   openssl rand -base64 64
JWT_SECRET=CAMBIA_ESTO_genera_con_openssl_rand_base64_64_minimo_64_caracteres
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# ─── CORS ───────────────────────────────────────────────────────
# En producción NO puede contener "localhost". Debe ser el host de Caddy.
CORS_ALLOWED_ORIGINS=https://flotillas.internal

# ─── Cloudflare Turnstile (CAPTCHA portal público) ──────────────
# OBLIGATORIO con NODE_ENV=production: protege el portal público de cargas.
# Usa tu secret REAL de Cloudflare. La "test key" always-pass de Cloudflare
# (1x0000000000000000000000000000000AA) deja el captcha decorativo: SOLO para QA
# tras VPN, NUNCA en staging accesible ni en producción (env.ts la rechaza en prod).
TURNSTILE_SECRET=CAMBIA_ESTO_secret_real_de_turnstile
# Si vas a EJERCITAR el portal público (/cargas/registro-rapido), el site key
# del frontend es build-time (NEXT_PUBLIC_*): verifica su nombre exacto en el
# código web y hornéalo en el build con la test site key always-pass:
#   1x00000000000000000000AA

# ─── Rate limits (defaults; súbelos si harás pruebas automatizadas) ──
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SEC=60
RATE_LIMIT_PUBLIC_MAX=10
RATE_LIMIT_PUBLIC_WINDOW_SEC=60

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Sentry (opcional; vacío = desactivado) ─────────────────────
# OJO: si pones un DSN, debe tener formato válido o env.ts ABORTA el arranque.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Frontend (Next.js) ─────────────────────────────────────────
# Déjalo vacío: el web usará ruta relativa /api proxiada por Next detrás de Caddy.
# (Recordatorio: las NEXT_PUBLIC_* se hornean en build; cambiarlas exige rebuild.)
NEXT_PUBLIC_API_URL=
