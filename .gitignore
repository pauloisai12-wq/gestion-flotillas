# Dependencias
node_modules/

# Variables de entorno (contraseñas, secretos)
# Cubre .env, .env.staging, .env.production, .env.local, etc.
# Solo se versionan las plantillas *.example.
.env
.env.*
!.env.example
!.env.public.example

# CA interna de Caddy exportada (root.crt) — se distribuye a los revisores fuera
# de banda; NUNCA se versiona. Ver flotillas-runbook.md §2 / GUIA §6.
*caddy*root.crt
flotillas-caddy-root.crt

# Next.js build
.next/

# TypeScript build
dist/

# Prisma
prisma/*.db

# Docker volumes
postgres_data/
redis_data/

# Archivos de prueba residuales de Fase 0
api/test-*.ts

# OS
Thumbs.db
.DS_Store

# Python (worker) — bytecode compilado
__pycache__/
*.pyc

# Archivos subidos por usuarios (runtime, no versionar)
api/uploads/*
!api/uploads/.gitkeep

# Reportes generados por el worker (runtime, no versionar)
storage/reports/*
!storage/reports/.gitkeep

# Logs
*.log