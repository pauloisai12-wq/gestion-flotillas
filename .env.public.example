# ============================================================================
# flotillas-v2 — plantilla de .env para QA PÚBLICO (VPS dedicado, HTTPS real)
# ----------------------------------------------------------------------------
# Copia este archivo a `.env` EN EL VPS y reemplaza cada CAMBIA_ESTO_*.
# NUNCA lo subas al repo.   Permisos:  chmod 600 .env
#
# Diferencia vs env.staging.plantilla.txt (servidor de casa, VPN-only): aquí el
# stack se EXPONE a internet desde un VPS desechable, con dominio público y cert
# Let's Encrypt automático (Caddyfile.public + docker-compose.public.yml). Acceso
# TOTALMENTE ABIERTO: la defensa es el login + rate-limit + credenciales fuertes.
#
# Los placeholders CAMBIA_ESTO_* están elegidos para que api/src/config/env.ts los
# RECHACE al arranque (NODE_ENV=production): olvidar uno produce un fallo claro, no
# un arranque inseguro. deploy-public.sh además los detecta antes de levantar Postgres.
#
# Despliegue:  ./deploy-public.sh
# ============================================================================

# --- Entorno (OBLIGATORIO; el compose lo fuerza sin fallback) ---------------
NODE_ENV=production

# --- PostgreSQL (OBLIGATORIO) -----------------------------------------------
POSTGRES_USER=flotillas_app
POSTGRES_PASSWORD=CAMBIA_ESTO_password_postgres    # genera:  openssl rand -hex 24   (hex = sin / + = que rompen la URL)
POSTGRES_DB=flotillas

# --- Redis (OBLIGATORIO: redis-server --requirepass) ------------------------
REDIS_PASSWORD=CAMBIA_ESTO_password_redis          # genera:  openssl rand -base64 24

# --- DATABASE_URL / REDIS_URL (OPCIONALES) ----------------------------------
# El docker-compose.yml las DERIVA de las credenciales de arriba; normalmente NO
# hace falta definirlas. Descoméntalas SOLO si apuntas a BD/Redis externos. Si las
# defines, la password va LITERAL en la URL (el .env no interpola ${...}).
# DATABASE_URL=postgresql://flotillas_app:<MISMA_PASSWORD_POSTGRES>@postgres:5432/flotillas?connection_limit=10
# REDIS_URL=redis://:<MISMA_PASSWORD_REDIS>@redis:6379

# --- Autenticación (OBLIGATORIO en prod) ------------------------------------
JWT_SECRET=CAMBIA_ESTO_genera_con_openssl_rand_base64_64   # >= 64 chars: openssl rand -base64 64
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12                                   # >= 12 en producción

# --- CORS (producción NO admite localhost) ----------------------------------
# DEBE ser tu dominio público EXACTO (mismo que en Caddyfile.public), con https://,
# SIN puerto y SIN slash final.
CORS_ALLOWED_ORIGINS=https://flotillas-qa.duckdns.org

# --- Proxy: cadena Caddy -> Next -> API (recupera la IP real del cliente) ----
# El compose ya inyecta el default 2; esto lo deja explícito. NUNCA 'true'.
TRUST_PROXY=2

# --- Cloudflare Turnstile (DESHABILITADO por defecto) ------------------------
# QA abierto + rate-limit del portal público (10/60s) sobre datos demo desechables.
# Si quieres blindar el portal público contra bots, pon TURNSTILE_ENABLED=true y los
# valores REALES de https://dash.cloudflare.com (env.ts rechaza las test keys), y
# registra tu hostname (p.ej. *.duckdns.org) en Turnstile. La site key es BUILD-TIME
# (cambiarla exige `$COMPOSE build web`).
TURNSTILE_ENABLED=false
NEXT_PUBLIC_TURNSTILE_ENABLED=false
# TURNSTILE_SECRET=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Web build-time (dejar el default) --------------------------------------
# BUILD-TIME: horneadas en la imagen web; cambiarlas exige `$COMPOSE build web`.
API_PROXY_TARGET=http://api:3001
NEXT_PUBLIC_API_URL=

# --- Observabilidad (OPCIONAL; vacío = desactivado) -------------------------
# Si pones un DSN, debe tener formato válido o env.ts ABORTA el arranque.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info

# --- Rate limits (OPCIONAL; defaults razonables) ----------------------------
# RATE_LIMIT_LOGIN_MAX=5
# RATE_LIMIT_LOGIN_WINDOW_SEC=60
# RATE_LIMIT_PUBLIC_MAX=10
# RATE_LIMIT_PUBLIC_WINDOW_SEC=60

# --- Primer ADMIN (one-time, tras el primer deploy) -------------------------
# La BD arranca vacía y el seed demo está bloqueado en producción. Crea el primer
# usuario ADMIN con el script bootstrap-admin (idempotente). Puedes definir estos
# valores aquí (chmod 600) o pasarlos con -e al ejecutar el script:
#   $COMPOSE run --rm -e ADMIN_EMAIL=tu@correo.com -e ADMIN_PASSWORD='...' \
#     api node dist/scripts/bootstrap-admin.js
# ADMIN_EMAIL=tu@correo.com
# ADMIN_PASSWORD=               # mínimo 12 caracteres
# ADMIN_NAME=Administrador

# --- Seed demo/QA (RECOMENDADO para QA: dashboards poblados) -----------------
# Datos demo (50 vehículos, 30 operadores, etc.). El seed está deshabilitado con
# NODE_ENV=production, así que se corre UNA vez con override de entorno. DEFINE
# contraseñas FUERTES aquí (en un box público admin123 sería un takeover inmediato):
#   $COMPOSE run --rm -e NODE_ENV=development \
#     -e SEED_ADMIN_PASSWORD='...' -e SEED_SUPER_PASSWORD='...' \
#     -e SEED_EXECUTOR_PASSWORD='...' -e SEED_WORKSHOP_PASSWORD='...' \
#     api npx prisma db seed
# SEED_ADMIN_PASSWORD=
# SEED_SUPER_PASSWORD=
# SEED_EXECUTOR_PASSWORD=
# SEED_WORKSHOP_PASSWORD=
