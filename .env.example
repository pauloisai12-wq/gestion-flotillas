# ────────────────────────────────────────────────────────────────
# Variables de entorno — copia este archivo a `.env` y completa los valores.
# NUNCA commitees el archivo .env real.
# ────────────────────────────────────────────────────────────────

# ─── Base de datos PostgreSQL ───────────────────────────────────
POSTGRES_USER=tu_usuario
POSTGRES_PASSWORD=tu_password
POSTGRES_DB=tu_base_de_datos
# Para servicios dentro de docker-compose (host = postgres)
# El connection_limit dimensiona el pool de Prisma. Default = num_cpus*2+1,
# suele quedar corto en staging/prod con BullMQ + jobs + healthchecks.
# Recomendado 20-30 según concurrencia esperada.
DATABASE_URL=postgresql://tu_usuario:tu_password@postgres:5432/tu_base_de_datos?connection_limit=20
# Para scripts/CLI corriendo en host (host = localhost:5433)
DATABASE_URL_LOCAL=postgresql://tu_usuario:tu_password@localhost:5433/tu_base_de_datos

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# Usadas por BullMQ en config/queue.ts (host y puerto separados)
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Autenticación / JWT ────────────────────────────────────────
# Mínimo 32 caracteres en dev, 64 en prod. Genera uno con: openssl rand -base64 64
JWT_SECRET=cambia_esto_a_un_valor_aleatorio_de_64_caracteres_minimo_en_prod
JWT_EXPIRES_IN=8h
# Rondas de bcrypt para hash de contraseñas (mín 10, recomendado 12 en prod)
BCRYPT_ROUNDS=12

# ─── CORS ───────────────────────────────────────────────────────
# Lista separada por comas. En prod NO debe contener localhost.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Cloudflare Turnstile (CAPTCHA portal público) ──────────────
# Opcional en dev, OBLIGATORIO en producción.
TURNSTILE_SECRET=

# ─── Rate limits ────────────────────────────────────────────────
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SEC=60
RATE_LIMIT_PUBLIC_MAX=10
RATE_LIMIT_PUBLIC_WINDOW_SEC=60

# ─── Logging ────────────────────────────────────────────────────
# Niveles: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ─── Entorno ────────────────────────────────────────────────────
NODE_ENV=development
# Puerto en que escucha la API
PORT=3001

# ─── Sentry (observabilidad de errores) ─────────────────────────
# Si los DSN están vacíos, Sentry no se activa (modo dev sin telemetría).
# Para activarlo: crear proyecto en sentry.io y pegar el DSN aquí.
# Backend (Express + Node):
SENTRY_DSN=
# Frontend (Next.js — el prefijo NEXT_PUBLIC_ lo expone al browser):
NEXT_PUBLIC_SENTRY_DSN=
# Solo si quieres upload de sourcemaps en build (opcional):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Frontend (Next.js) ─────────────────────────────────────────
# Si está vacío, el frontend usa rutas relativas via proxy interno (recomendado con ngrok)
NEXT_PUBLIC_API_URL=http://localhost:3001
